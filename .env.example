# ============================================================
# ZK Rollup Payment System - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# DO NOT commit your .env file to version control.

# ─── PostgreSQL Connection Details ──────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=zkrollup
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/zkrollup

# ─── Backend Configuration ───────────────────────────────────
API_PORT=4000

# ─── Blockchain Connection ───────────────────────────────────
RPC_URL=http://hardhat:8545

# ─── Relayer Wallet ──────────────────────────────────────────
# Use Account #0 from Hardhat node output (the deployer/relayer)
# Example from default Hardhat mnemonic:
RELAYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── Test User Wallets ───────────────────────────────────────
# Use Account #1 from Hardhat node output for USER_A
USER_A_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
USER_A_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Use Account #2 from Hardhat node output for USER_B (recipient only)
USER_B_ADDRESS=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC

# ─── Flutter Frontend ────────────────────────────────────────
# Override at build time via --dart-define=API_BASE_URL=...
API_BASE_URL=http://localhost:4000
